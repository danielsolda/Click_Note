# Copie para .env e ajuste
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clicknote
DB_SSL=false
DB_POOL_MAX=10
APP_ENV=development
TZ=America/Sao_Paulo

# Segredo JWT — gere um valor aleatório forte em produção:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-valor-em-producao

# Credenciais do admin inicial (usadas por npm run db:seed-admin)
ADMIN_EMAIL=admin@clicknote.app
ADMIN_PASSWORD=mude-em-producao!
ADMIN_NAME=Admin
